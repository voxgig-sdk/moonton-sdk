{
  "openapi": "3.0.3",
  "info": {
    "title": "Moonton API",
    "description": "The Moonton API provides access to various game-related functionalities, allowing developers to fetch game data, player statistics, and manage in-game transactions. It aims to enhance user engagement by offering features that integrate seamlessly with Moonton's gaming ecosystem.",
    "version": "1.0.0",
    "contact": {
      "name": "Moonton API Support",
      "url": "https://en.moonton.com/games/index.html"
    }
  },
  "servers": [
    {
      "url": "https://api.moonton.com/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/games": {
      "get": {
        "summary": "Get games list",
        "description": "Retrieves a list of available games in the Moonton ecosystem",
        "operationId": "getGames",
        "tags": [
          "Games"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of games to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of games to skip for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with games list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Game"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of games available",
                      "example": 15
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Game": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the game",
            "example": "mlbb_001"
          },
          "name": {
            "type": "string",
            "description": "Name of the game",
            "example": "Mobile Legends: Bang Bang"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the game",
            "example": "5v5 MOBA game for mobile devices"
          },
          "genre": {
            "type": "string",
            "description": "Game genre",
            "example": "MOBA"
          },
          "releaseDate": {
            "type": "string",
            "format": "date",
            "description": "Release date of the game",
            "example": "2016-07-14"
          },
          "platforms": {
            "type": "array",
            "description": "Platforms where the game is available",
            "items": {
              "type": "string",
              "enum": [
                "iOS",
                "Android",
                "PC"
              ]
            },
            "example": [
              "iOS",
              "Android"
            ]
          },
          "active": {
            "type": "boolean",
            "description": "Whether the game is currently active",
            "example": true
          },
          "playerCount": {
            "type": "integer",
            "description": "Current active player count",
            "example": 100000000
          }
        },
        "required": [
          "id",
          "name",
          "genre"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code",
                "example": "INVALID_REQUEST"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message",
                "example": "The request parameters are invalid"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Contact Moonton to obtain your API key."
      }
    }
  },
  "tags": [
    {
      "name": "Games",
      "description": "Operations related to game data and information"
    }
  ]
}
